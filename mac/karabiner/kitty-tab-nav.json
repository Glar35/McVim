{
  "title": "Kitty: Cmd+Shift+Arrow → tab switching",
  "rules": [
    {
      "description": "In kitty, remap Cmd+Shift+Right/Left to Cmd+] / Cmd+[ (kitty's tab nav)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_arrow",
            "modifiers": {
              "mandatory": ["left_command", "left_shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "close_bracket",
              "modifiers": ["left_command"]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^net\\.kovidgoyal\\.kitty$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "left_arrow",
            "modifiers": {
              "mandatory": ["left_command", "left_shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "open_bracket",
              "modifiers": ["left_command"]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^net\\.kovidgoyal\\.kitty$"]
            }
          ]
        }
      ]
    }
  ]
}
